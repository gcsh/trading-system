# Broker selection: alpaca_paper (default, safe) | alpaca_live | robinhood
BROKER=alpaca_paper

# Alpaca credentials — get free paper keys at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Robinhood credentials (unofficial API - use with caution)
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password
# Optional TOTP secret (base32) for automated MFA. Leave blank if you want interactive challenge.
ROBINHOOD_MFA_SECRET=

# NewsAPI key - get one at https://newsapi.org/
NEWS_API_KEY=your_newsapi_key

# Heatseeker (GEX gamma exposure) — optional. Falls back to Cboe/yfinance
# computation when blank.
FLASHALPHA_API_KEY=optional
GEX_CACHE_TTL=60

# Flowseeker (institutional options flow) — optional. Falls back to yfinance
# unusual-volume detection (volume > 3x OI) when blank.
UNUSUAL_WHALES_API_KEY=your_key_here
FLOW_MIN_PREMIUM=50000
FLOW_URGENCY_THRESHOLD=0.8

# Safety: keep true until you are confident
PAPER_MODE=true

# Default ticker universe scanned each cycle
DEFAULT_TICKERS=SPY,AAPL,TSLA,NVDA,QQQ,MSFT,AMD

# Local database path
DB_PATH=./trading_bot.db

# API host / port
API_HOST=0.0.0.0
API_PORT=8000

# Stage-18a free public data sources. All gracefully no-op when missing.

# FRED (Federal Reserve Economic Data) — free signup at
#   https://fred.stlouisfed.org/docs/api/api_key.html
TB_FRED_API_KEY=

# SEC EDGAR — SEC requires a User-Agent identifying the operator
# Format: "Operator Name (contact@email)"
TB_SEC_USER_AGENT=

# How often (hours) the scheduler refreshes EDGAR filings for the watchlist
TB_EDGAR_REFRESH_INTERVAL_HOURS=6
